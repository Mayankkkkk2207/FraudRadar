# FraudRadar Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration
POSTGRES_USER=fraudradar
POSTGRES_PASSWORD=fraudradar
POSTGRES_DB=fraudradar
DATABASE_URL=postgresql+psycopg2://fraudradar:fraudradar@postgres:5432/fraudradar

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_EXTERNAL_HOST=localhost
KAFKA_HOST=kafka
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_RAW_TOPIC=transactions
KAFKA_SCORED_TOPIC=fraud_scores
KAFKA_TOPIC_PARTITIONS=1
KAFKA_TOPIC_REPLICATION_FACTOR=1

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Model Configuration
MODEL_DIR=/app/models
FRAUD_THRESHOLD=0.7
HIGH_RISK_THRESHOLD=0.85

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ALLOW_SIGN_UP=false

# Application Settings
APP_NAME=FraudRadar
APP_VERSION=1.0.0
